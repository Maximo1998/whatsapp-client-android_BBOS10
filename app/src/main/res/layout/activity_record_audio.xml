<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".RecordAudioActivity">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Record Audio"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimaryDark"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- Status Text (Shows instructions) -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Press record to start"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Visualizer -->
    <com.visualizer.amplitude.AudioRecordView
        android:id="@+id/audioRecordView"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:chunkAlignTo="bottom"
        app:chunkRoundedCorners="true"
        app:chunkSoftTransition="true"
        app:chunkColor="@android:color/holo_blue_dark"
        app:chunkSpace="2dp"
        app:chunkWidth="3dp"
        app:chunkMaxHeight="64dp"
        app:chunkMinHeight="4dp"
        app:direction="leftToRight"
        android:layout_marginBottom="16dp" />

    <!-- Timer -->
    <TextView
        android:id="@+id/tv_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:gravity="center"
        android:textSize="48sp"
        android:textColor="@android:color/black"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp" />

    <!-- Control Buttons (Record, Cancel, Play) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <!-- Cancel Button -->
        <ImageButton
            android:id="@+id/ib_cancel"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@drawable/rounded_button_cancel"
            android:scaleType="centerInside"
            android:contentDescription="Cancel"
            android:layout_marginEnd="16dp" />

        <!-- Main Record Button -->
        <ImageButton
            android:id="@+id/ib_record"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_mic_none_black_24dp"
            android:background="@drawable/rounded_button_record"
            android:scaleType="centerInside"
            android:tint="@android:color/white"
            android:contentDescription="Record" />

        <!-- Play Button -->
        <ImageButton
            android:id="@+id/ib_play"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_play_arrow_black_24dp"
            android:background="@drawable/rounded_button_play"
            android:scaleType="centerInside"
            android:contentDescription="Play"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Send Button (Visible when recording is done) -->
    <Button
        android:id="@+id/ib_upload"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="✓ Send Audio"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@android:color/holo_green_dark"
        android:textColor="@android:color/white"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

</LinearLayout>